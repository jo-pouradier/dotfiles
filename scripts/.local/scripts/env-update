#!/bin/bash
# Fedora update script

echo "Updating DNF..."
sudo dnf upgrade --refresh -y
sudo dnf autoremove -y

echo "Updating Flatpaks..."
flatpak update -y

echo "Updating NodeJS CLI (pnpm)..."
pnpm update -g

echo "Updating Rust tools..."
rustup update

echo "Update OpenCode..."
opencode upgrade

echo "All done ✅"

